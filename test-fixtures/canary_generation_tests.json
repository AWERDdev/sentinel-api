                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"token_type\": \"kube_config\",\n    \"name\": \"Malicious Type Test Object\",\n    \"alert_email\": \"test@company.local\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/canary/generate-token",
              "host": ["{{base_url}}"],
